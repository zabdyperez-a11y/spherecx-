generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum OrgStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SUPERVISOR
  TEAM_LEAD
  QA_ANALYST
  AGENT
}

enum EvalStatus {
  DRAFT
  SUBMITTED
  DISPUTED
  RESOLVED
  ACKNOWLEDGED
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  RESIGNED
  SUSPENDED
}

enum IncidentSeverity {
  VERBAL_WARNING
  WRITTEN_WARNING
  FINAL_WARNING
  SUSPENSION
  TERMINATION
}

enum ReviewType {
  MONTHLY
  QUARTERLY
  ANNUAL
  PIP
}

enum TrainingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

enum LeaveStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum LeaveType {
  PTO
  SICK
  PERSONAL
  BEREAVEMENT
  UNPAID
  OTHER
}

model Organization {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  plan          Plan      @default(FREE)
  status        OrgStatus @default(TRIAL)
  maxUsers      Int       @default(3)
  maxEvals      Int       @default(50)
  trialEndsAt   DateTime?
  allowedDomain String?
  users         User[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  name             String?
  password         String?
  resetToken       String?
  resetTokenExpiry DateTime?
  role             Role         @default(AGENT)
  orgId            String?
  org              Organization? @relation(fields: [orgId], references: [id])
  teamId           String?
  team             Team?        @relation(fields: [teamId], references: [id])
  evaluationsDone  Evaluation[] @relation("EvaluatorRelation")
  evaluationsOf    Evaluation[] @relation("AgentRelation")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Team {
  id        String   @id @default(cuid())
  name      String
  orgId     String?
  members   User[]
  createdAt DateTime @default(now())
}

model Scorecard {
  id          String      @id @default(cuid())
  name        String
  description String?
  isActive    Boolean     @default(true)
  orgId       String?
  sections    Section[]
  evaluations Evaluation[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Section {
  id          String      @id @default(cuid())
  name        String
  scorecardId String
  scorecard   Scorecard   @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  criteria    Criterion[]
  order       Int         @default(0)
}

model Criterion {
  id          String  @id @default(cuid())
  question    String
  description String?
  weight      Float   @default(1)
  isCritical  Boolean @default(false)
  sectionId   String
  section     Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  answers     Answer[]
}

model Evaluation {
  id             String             @id @default(cuid())
  scorecardId    String
  scorecard      Scorecard          @relation(fields: [scorecardId], references: [id])
  agentId        String
  agent          User               @relation("AgentRelation", fields: [agentId], references: [id])
  evaluatorId    String
  evaluator      User               @relation("EvaluatorRelation", fields: [evaluatorId], references: [id])
  orgId          String?
  callDate       DateTime
  callId         String?
  recordingUrl   String?
  transcript     String?
  totalScore     Float?
  passed         Boolean?
  notes          String?
  coachingNote   String?
  status         EvalStatus         @default(DRAFT)
  acknowledgedAt DateTime?
  acknowledgedBy String?
  answers        Answer[]
  comments       EvaluationComment[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model Answer {
  id          String    @id @default(cuid())
  evaluationId String
  evaluation  Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  criterionId String
  criterion   Criterion  @relation(fields: [criterionId], references: [id])
  score       Int
  note        String?
}

model EvaluationComment {
  id           String     @id @default(cuid())
  evaluationId String
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  userId       String?
  userName     String
  userRole     String?
  content      String
  createdAt    DateTime   @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  orgId     String?
  userId    String?
  userEmail String
  userName  String?
  userRole  String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

model Employee {
  id               String               @id @default(cuid())
  orgId            String?
  userId           String?              @unique
  employeeId       String?
  firstName        String
  lastName         String
  email            String
  phone            String?
  jobTitle         String?
  department       String?
  teamId           String?
  managerId        String?
  hireDate         DateTime
  terminationDate  DateTime?
  status           EmploymentStatus     @default(ACTIVE)
  employmentType   String?
  payRate          Float?
  payType          String?
  location         String?
  notes            String?
  emergencyContact String?
  documents        EmployeeDocument[]
  incidents        DisciplinaryAction[]
  reviews          PerformanceReview[]
  attendance       AttendanceRecord[]
  shifts           ShiftAssignment[]
  trainings        TrainingCompletion[]
  leaveRequests    LeaveRequest[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model DisciplinaryAction {
  id           String           @id @default(cuid())
  employeeId   String
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orgId        String?
  type         IncidentSeverity
  date         DateTime
  description  String
  action       String
  issuedBy     String
  witnessedBy  String?
  followUpDate DateTime?
  resolved     Boolean          @default(false)
  resolvedAt   DateTime?
  notes        String?
  createdAt    DateTime         @default(now())
}

model PerformanceReview {
  id                String     @id @default(cuid())
  employeeId        String
  employee          Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orgId             String?
  reviewType        ReviewType
  reviewDate        DateTime
  reviewedBy        String
  qaScore           Float?
  attendanceScore   Float?
  productivityScore Float?
  overallScore      Float?
  strengths         String?
  improvements      String?
  goals             String?
  employeeComment   String?
  acknowledgedAt    DateTime?
  status            String     @default("DRAFT")
  createdAt         DateTime   @default(now())
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name       String
  type       String
  url        String?
  uploadedAt DateTime @default(now())
}

model Shift {
  id          String            @id @default(cuid())
  orgId       String?
  name        String
  startTime   String
  endTime     String
  days        String
  color       String            @default("#3b82f6")
  assignments ShiftAssignment[]
  createdAt   DateTime          @default(now())
}

model ShiftAssignment {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftId    String
  shift      Shift    @relation(fields: [shiftId], references: [id])
  date       DateTime
  status     String   @default("SCHEDULED")
  notes      String?
}

model AttendanceRecord {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orgId       String?
  date        DateTime
  clockIn     DateTime?
  clockOut    DateTime?
  hoursWorked Float?
  status      String
  notes       String?
  createdAt   DateTime  @default(now())
}

model TrainingModule {
  id          String               @id @default(cuid())
  orgId       String?
  title       String
  description String?
  category    String?
  duration    Int?
  content     String?
  isRequired  Boolean              @default(false)
  dueWithin   Int?
  completions TrainingCompletion[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model TrainingCompletion {
  id          String         @id @default(cuid())
  employeeId  String
  employee    Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  moduleId    String
  module      TrainingModule @relation(fields: [moduleId], references: [id])
  status      TrainingStatus @default(NOT_STARTED)
  startedAt   DateTime?
  completedAt DateTime?
  score       Float?
  expiresAt   DateTime?
}

model LeaveRequest {
  id         String      @id @default(cuid())
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orgId      String?
  type       LeaveType
  startDate  DateTime
  endDate    DateTime
  days       Float
  reason     String?
  status     LeaveStatus @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?
  reviewNote String?
  createdAt  DateTime    @default(now())
}

model OnboardingTemplate {
  id        String           @id @default(cuid())
  orgId     String?
  name      String
  tasks     OnboardingTask[]
  createdAt DateTime         @default(now())
}

model OnboardingTask {
  id          String               @id @default(cuid())
  templateId  String
  template    OnboardingTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueWithin   Int?
  assignedTo  String?
  order       Int                  @default(0)
  completions OnboardingCompletion[]
}

model OnboardingCompletion {
  id          String         @id @default(cuid())
  taskId      String
  task        OnboardingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employeeId  String
  completedAt DateTime?
  completedBy String?
  notes       String?
}

model Campaign {
  id          String           @id @default(cuid())
  orgId       String?
  name        String
  type        String
  status      String           @default("ACTIVE")
  startDate   DateTime?
  endDate     DateTime?
  description String?
  targetCalls Int?
  script      String?
  metrics     CampaignMetric[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model CampaignMetric {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  date       DateTime
  totalCalls Int      @default(0)
  answered   Int      @default(0)
  converted  Int      @default(0)
  avgHandle  Float?
  createdAt  DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
