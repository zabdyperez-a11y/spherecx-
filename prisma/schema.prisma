generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum OrgStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

enum Role {
  SUPER_ADMIN
  ADMIN
  QA_ANALYST
  TEAM_LEAD
  AGENT
}

enum EvalStatus {
  DRAFT
  SUBMITTED
  DISPUTED
  RESOLVED
  ACKNOWLEDGED
}

model Organization {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  plan        Plan        @default(FREE)
  status      OrgStatus   @default(TRIAL)
  maxUsers      Int         @default(3)
  maxEvals      Int         @default(50)
  contactName   String?
  contactEmail  String?
  allowedDomain String?
  notes         String?
  trialEndsAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  users       User[]
  teams       Team[]
  scorecards  Scorecard[]
  evaluations Evaluation[]
}

model User {
  id             String       @id @default(cuid())
  name           String?
  email          String       @unique
  password          String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  emailVerified  DateTime?
  image          String?
  role           Role         @default(AGENT)
  orgId          String?
  org            Organization? @relation(fields: [orgId], references: [id])
  teamId         String?
  team           Team?        @relation(fields: [teamId], references: [id])
  accounts       Account[]
  sessions       Session[]
  evaluationsBy  Evaluation[] @relation("EvaluatorRelation")
  evaluationsOf  Evaluation[] @relation("AgentRelation")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Team {
  id          String       @id @default(cuid())
  name        String
  description String?
  orgId       String?
  org         Organization? @relation(fields: [orgId], references: [id])
  members     User[]
  scorecards  Scorecard[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Scorecard {
  id          String       @id @default(cuid())
  name        String
  description String?
  orgId       String?
  org         Organization? @relation(fields: [orgId], references: [id])
  teamId      String?
  team        Team?        @relation(fields: [teamId], references: [id])
  sections    Section[]
  evaluations Evaluation[]
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Section {
  id          String      @id @default(cuid())
  name        String
  weight      Float       @default(1.0)
  scorecardId String
  scorecard   Scorecard   @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  criteria    Criterion[]
  order       Int         @default(0)
}

model Criterion {
  id          String     @id @default(cuid())
  question    String
  description String?
  weight      Float      @default(1.0)
  isCritical  Boolean    @default(false)
  sectionId   String
  section     Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  answers     Answer[]
  order       Int        @default(0)
}

model Evaluation {
  id           String       @id @default(cuid())
  orgId        String?
  org          Organization? @relation(fields: [orgId], references: [id])
  scorecardId  String
  scorecard    Scorecard    @relation(fields: [scorecardId], references: [id])
  evaluatorId  String
  evaluator    User         @relation("EvaluatorRelation", fields: [evaluatorId], references: [id])
  agentId      String
  agent        User         @relation("AgentRelation", fields: [agentId], references: [id])
  callDate     DateTime
  callId       String?
  recordingUrl String?
  transcript   String?
  totalScore   Float?
  passed       Boolean?
  notes        String?
  answers      Answer[]
  status       EvalStatus   @default(DRAFT)
  acknowledgedAt DateTime?
  acknowledgedBy String?
  coachingNote String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  comments     EvaluationComment[]
}

model Answer {
  id           String     @id @default(cuid())
  evaluationId String
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  criterionId  String
  criterion    Criterion  @relation(fields: [criterionId], references: [id])
  score        Int
  note         String?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EvaluationComment {
  id           String     @id @default(cuid())
  evaluationId String
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  userId       String?
  userName     String
  userRole     String?
  content      String
  createdAt    DateTime   @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model AuditLog {
  id         String   @id @default(cuid())
  orgId      String?
  userId     String?
  userEmail  String
  userName   String?
  userRole   String?
  action     String
  entity     String
  entityId   String?
  entityName String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([orgId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

// ─── HR MODULE ───────────────────────────────────────────

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  RESIGNED
  SUSPENDED
}

enum IncidentSeverity {
  VERBAL_WARNING
  WRITTEN_WARNING
  FINAL_WARNING
  SUSPENSION
  TERMINATION
}

enum ReviewType {
  MONTHLY
  QUARTERLY
  ANNUAL
  PIP
}

model Employee {
  id               String           @id @default(cuid())
  orgId            String?
  userId           String?          @unique
  employeeId       String?
  firstName        String
  lastName         String
  email            String
  phone            String?
  jobTitle         String?
  department       String?
  teamId           String?
  managerId        String?
  hireDate         DateTime
  terminationDate  DateTime?
  status           EmploymentStatus @default(ACTIVE)
  employmentType   String?
  payRate          Float?
  payType          String?
  location         String?
  notes            String?
  emergencyContact String?
  documents        EmployeeDocument[]
  incidents        DisciplinaryAction[]
  reviews          PerformanceReview[]
  attendance       AttendanceRecord[]
  shifts           ShiftAssignment[]
  trainings        TrainingCompletion[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model DisciplinaryAction {
  id          String           @id @default(cuid())
  employeeId  String
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orgId       String?
  type        IncidentSeverity
  date        DateTime
  description String
  action      String
  issuedBy    String
  witnessedBy String?
  followUpDate DateTime?
  resolved    Boolean          @default(false)
  resolvedAt  DateTime?
  notes       String?
  createdAt   DateTime         @default(now())
}

model PerformanceReview {
  id              String      @id @default(cuid())
  employeeId      String
  employee        Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orgId           String?
  reviewType      ReviewType
  reviewDate      DateTime
  reviewedBy      String
  qaScore         Float?
  attendanceScore Float?
  productivityScore Float?
  overallScore    Float?
  strengths       String?
  improvements    String?
  goals           String?
  employeeComment String?
  acknowledgedAt  DateTime?
  status          String      @default("DRAFT")
  createdAt       DateTime    @default(now())
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name       String
  type       String
  url        String?
  uploadedAt DateTime @default(now())
}

// ─── SCHEDULING MODULE ────────────────────────────────────

model Shift {
  id          String            @id @default(cuid())
  orgId       String?
  name        String
  startTime   String
  endTime     String
  days        String
  color       String            @default("#3b82f6")
  assignments ShiftAssignment[]
  createdAt   DateTime          @default(now())
}

model ShiftAssignment {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftId    String
  shift      Shift    @relation(fields: [shiftId], references: [id])
  date       DateTime
  status     String   @default("SCHEDULED")
  notes      String?
}

model AttendanceRecord {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orgId      String?
  date       DateTime
  clockIn    DateTime?
  clockOut   DateTime?
  hoursWorked Float?
  status     String
  notes      String?
  createdAt  DateTime @default(now())
}

// ─── TRAINING MODULE ──────────────────────────────────────

enum TrainingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

model TrainingModule {
  id          String              @id @default(cuid())
  orgId       String?
  title       String
  description String?
  category    String?
  duration    Int?
  content     String?
  isRequired  Boolean             @default(false)
  dueWithin   Int?
  completions TrainingCompletion[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model TrainingCompletion {
  id         String         @id @default(cuid())
  employeeId String
  employee   Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  moduleId   String
  module     TrainingModule @relation(fields: [moduleId], references: [id])
  status     TrainingStatus @default(NOT_STARTED)
  startedAt  DateTime?
  completedAt DateTime?
  score       Float?
  expiresAt   DateTime?
}

// ─── OPERATIONS MODULE ────────────────────────────────────

model Campaign {
  id          String   @id @default(cuid())
  orgId       String?
  name        String
  type        String
  status      String   @default("ACTIVE")
  startDate   DateTime?
  endDate     DateTime?
  description String?
  targetCalls Int?
  script      String?
  metrics     CampaignMetric[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CampaignMetric {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  date        DateTime
  totalCalls  Int      @default(0)
  answered    Int      @default(0)
  converted   Int      @default(0)
  avgHandle   Float?
  createdAt   DateTime @default(now())
}
