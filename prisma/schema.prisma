generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  role          Role         @default(AGENT)
  teamId        String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  evaluationsOf Evaluation[] @relation("AgentRelation")
  evaluationsBy Evaluation[] @relation("EvaluatorRelation")
  sessions      Session[]
  team          Team?        @relation(fields: [teamId], references: [id])
}

model Team {
  id          String      @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  scorecards  Scorecard[]
  members     User[]
}

model Scorecard {
  id          String       @id @default(cuid())
  name        String
  description String?
  teamId      String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  evaluations Evaluation[]
  team        Team?        @relation(fields: [teamId], references: [id])
  sections    Section[]
}

model Section {
  id          String      @id @default(cuid())
  name        String
  weight      Float       @default(1.0)
  scorecardId String
  order       Int         @default(0)
  criteria    Criterion[]
  scorecard   Scorecard   @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
}

model Criterion {
  id          String   @id @default(cuid())
  question    String
  description String?
  weight      Float    @default(1.0)
  isCritical  Boolean  @default(false)
  sectionId   String
  order       Int      @default(0)
  answers     Answer[]
  section     Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

model Evaluation {
  id           String     @id @default(cuid())
  scorecardId  String
  evaluatorId  String
  agentId      String
  callDate     DateTime
  callId       String?
  recordingUrl String?
  transcript   String?
  totalScore   Float?
  passed       Boolean?
  notes        String?
  status       EvalStatus @default(DRAFT)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  answers      Answer[]
  agent        User       @relation("AgentRelation", fields: [agentId], references: [id])
  evaluator    User       @relation("EvaluatorRelation", fields: [evaluatorId], references: [id])
  scorecard    Scorecard  @relation(fields: [scorecardId], references: [id])
}

model Answer {
  id           String     @id @default(cuid())
  evaluationId String
  criterionId  String
  score        Int
  note         String?
  criterion    Criterion  @relation(fields: [criterionId], references: [id])
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  ADMIN
  QA_ANALYST
  TEAM_LEAD
  AGENT
}

enum EvalStatus {
  DRAFT
  SUBMITTED
  DISPUTED
  RESOLVED
}

enum LeaveStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum LeaveType {
  PTO
  SICK
  PERSONAL
  BEREAVEMENT
  UNPAID
  OTHER
}

model LeaveRequest {
  id          String      @id @default(cuid())
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orgId       String?
  type        LeaveType
  startDate   DateTime
  endDate     DateTime
  days        Float
  reason      String?
  status      LeaveStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime    @default(now())
}

model OnboardingTemplate {
  id        String            @id @default(cuid())
  orgId     String?
  name      String
  tasks     OnboardingTask[]
  createdAt DateTime          @default(now())
}

model OnboardingTask {
  id           String               @id @default(cuid())
  templateId   String
  template     OnboardingTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  dueWithin    Int?
  assignedTo   String?
  order        Int                  @default(0)
  completions  OnboardingCompletion[]
}

model OnboardingCompletion {
  id          String         @id @default(cuid())
  taskId      String
  task        OnboardingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employeeId  String
  completedAt DateTime?
  completedBy String?
  notes       String?
}
